{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 27,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "RINGOS_ENABLE_TESTING": "ON"
      }
    },
    {
      "name": "x64-debug",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/x64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "RINGOS_TARGET_ARCH": "x64"
      }
    },
    {
      "name": "arm64-debug",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/arm64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "RINGOS_TARGET_ARCH": "arm64"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-x64-debug",
      "configurePreset": "x64-debug"
    },
    {
      "name": "build-arm64-debug",
      "configurePreset": "arm64-debug"
    },
    {
      "name": "stage-x64-sdk-sysroot",
      "configurePreset": "x64-debug",
      "targets": [
        "ringos_sdk_sysroot"
      ]
    },
    {
      "name": "stage-arm64-sdk-sysroot",
      "configurePreset": "arm64-debug",
      "targets": [
        "ringos_sdk_sysroot"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "x64_emulator_unit",
      "configurePreset": "x64-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": true
      },
      "filter": {
        "include": {
          "name": "^x64_emulator_unit$"
        }
      }
    },
    {
      "name": "x64_win32_loader_unit",
      "configurePreset": "x64-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": true
      },
      "filter": {
        "include": {
          "name": "^x64_win32_loader_unit$"
        }
      }
    },
    {
      "name": "smoke_x64_native",
      "configurePreset": "x64-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": true
      },
      "filter": {
        "include": {
          "name": "^smoke_x64_native$"
        }
      }
    },
    {
      "name": "smoke_x64_ansi_c",
      "configurePreset": "x64-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": true
      },
      "filter": {
        "include": {
          "name": "^smoke_x64_ansi_c$"
        }
      }
    },
    {
      "name": "smoke_arm64_native",
      "configurePreset": "arm64-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": true
      },
      "filter": {
        "include": {
          "name": "^smoke_arm64_native$"
        }
      }
    },
    {
      "name": "smoke_arm64_ansi_c",
      "configurePreset": "arm64-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": true
      },
      "filter": {
        "include": {
          "name": "^smoke_arm64_ansi_c$"
        }
      }
    },
    {
      "name": "smoke_arm64_x64_emulator",
      "configurePreset": "arm64-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": true
      },
      "filter": {
        "include": {
          "name": "^smoke_arm64_x64_emulator$"
        }
      }
    }
  ]
}
